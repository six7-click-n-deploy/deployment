# ================================================================
# Server deployment env — used by docker-compose.deploy.yml 
# and staging additionally layers with docker-compose.staging.yml 
# ================================================================

# --- Image tags (pulled from ghcr.io/six7-click-n-deploy/*) ---
BACKEND_VERSION=latest
WORKER_VERSION=latest
FRONTEND_VERSION=latest

# --- Backend Postgres ---
DB_USER=postgres
DB_PASSWORD=change-me
DB_NAME=clickndeploy

# --- Backend app ---
SECRET_KEY=change-me-generate-with-secrets-token_hex-32
CORS_ORIGINS=["https://staging.example.dhbw.de"]

# --- GHCR auth (the six7-click-n-deploy images above are PRIVATE) ---
# The Ansible deploy reads these from the rsynced .env and runs `docker login
# ghcr.io` before pulling. Use a fine-grained PAT with ONLY the read:packages

GIT_USER=<your_github_username>
GIT_ACCESS_TOKEN=<github_access_token_for_cloning_app_repos>

# --- RabbitMQ (Celery broker) ---
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=change-me
RABBITMQ_VHOST=/

# --- Keycloak (added by docker-compose.deploy.yml) ---
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=change-me
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=change-me
# Must match the appstore-backend client secret in the dhbw realm:
KEYCLOAK_CLIENT_SECRET=<appstore_backend_client_secret>
# Defaults are fine for in-cluster use; override only if needed:
# KEYCLOAK_SERVER_URL=http://keycloak:8080
# KEYCLOAK_REALM=dhbw
# KEYCLOAK_CLIENT_ID=appstore-backend
# KEYCLOAK_ENABLED=true

# --- Staging only: test realm + Template-Seed ---
# On staging, docker-compose.staging.yml swaps the imported realm to
# keycloak/keycloak-export.json (the dhbw realm WITH test users; run `make keycloak-export`).
# The Template-Seed itself (test teacher + which app templates to create) is configured as
# Ansible vars in infrastructure/ansible/deploy_staging.yml — NOT in this file.
# IMPORTANT: KEYCLOAK_CLIENT_SECRET above must match the appstore-backend secret baked into
# keycloak-export.json, or the backend's Keycloak-admin features (user search) fail. Login
# itself is unaffected (validated offline against the realm public key).

