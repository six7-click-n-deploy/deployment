KEYCLOAK_CLIENT_SECRET=<your_keycloak_client_secret>
GIT_ACCESS_TOKEN=<your_github_access_token>

# Symmetric Fernet key shared by backend and worker. The backend encrypts
# OpenStack credentials at rest with this key; the worker uses the same key
# to decrypt the ciphertext envelope it receives via Celery. Generate one with:
#   python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
CREDENTIAL_ENCRYPTION_KEY=<32-byte-url-safe-base64-fernet-key>

# Django-style secret key for the backend. Generate one with:
#   python -c 'import secrets; print(secrets.token_hex(50))'
SECRET_KEY=<random-secret-key>

# App database (backend + alembic migrations)
DB_USER=postgres
DB_PASSWORD=<strong-password>
DB_NAME=appstore

# Keycloak admin credentials
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=<strong-password>

# Keycloak database
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=<strong-password>
KEYCLOAK_DB_NAME=keycloak

# RabbitMQ broker
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=<strong-password>

# Terraform remote state DB (worker-only). Defaults are fine for dev; in
# prod set TFSTATE_DB_PASSWORD to a strong secret. The container is on the
# worker-network only and is not reachable from the application backend.
TFSTATE_DB_USER=terraform
TFSTATE_DB_PASSWORD=<strong-password>
TFSTATE_DB_NAME=tfstate

# Public-facing base URL of the frontend — served by nginx on :443.
# Use https:// (nginx terminates TLS, no port needed).
# Ansible reads this to render keycloak/realm-export.json.j2.
APP_BASE_URL=https://<VM_IP>

# Must match APP_BASE_URL.
CORS_ORIGINS=["https://<VM_IP>"]

# Frontend env vars (injected at container start via docker-compose)
VITE_APP_URL=https://<VM_IP>
VITE_API_URL=https://<VM_IP>/api
VITE_KEYCLOAK_URL=https://<VM_IP>
