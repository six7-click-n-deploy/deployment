KEYCLOAK_CLIENT_SECRET=<your_keycloak_client_secret>
GIT_ACCESS_TOKEN=<your_github_access_token>

# Symmetric Fernet key shared by backend and worker. The backend encrypts
# OpenStack credentials at rest with this key; the worker uses the same key
# to decrypt the ciphertext envelope it receives via Celery. Generate one with:
#   python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
CREDENTIAL_ENCRYPTION_KEY=<32-byte-url-safe-base64-fernet-key>

# Terraform remote state DB (worker-only). Defaults are fine for dev; in
# prod set TFSTATE_DB_PASSWORD to a strong secret. The container is on the
# worker-network only and is not reachable from the application backend.
TFSTATE_DB_USER=terraform
TFSTATE_DB_PASSWORD=terraform
TFSTATE_DB_NAME=tfstate
